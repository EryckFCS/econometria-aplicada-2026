# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.coverage
htmlcov/
.pytest_cache/

# Virtual environments
.venv

# Quarto
/.quarto/
**/*.quarto_ipynb
**/*_files/
**/*_cache/
_site/

# Scratch — scripts operativos no versionables
scratch/

