# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.coverage
htmlcov/
.pytest_cache/

# Virtual environments
.venv

# Quarto
/.quarto/
**/*.quarto_ipynb*
**/*_files/
**/*_cache/
_site/

# Project data artifacts
data/*
!data/.gitkeep
scratch/*
!scratch/.gitkeep
reports/*
!reports/.gitkeep

# Archives and Large Files
*.zip
*.tar.gz
*.rar
*.7z

# Specific Exclusions
Photos*/
data/raw/excel/*.xlsx
data/raw/csv/*.csv
data/exports/*.xlsx

# Salidas de writing/ (libro Quarto)
writing/dist/
_freeze/
.ipynb_checkpoints/
render_log*.txt
.ruff_cache/

# Large Datasets and Vector Stores
*.sav
*.sqlite3
**/vector_store/
data/raw/external/

# Heavy Data Exclusion (Vaults Architecture)
docs/vaults/**/data/*.csv
docs/vaults/**/data/*.parquet
docs/vaults/**/data/*.xlsx
docs/vaults/**/data/*.dta
docs/vaults/**/data/*.sav
docs/vaults/**/data/*.db
docs/vaults/**/data/*.sqlite
